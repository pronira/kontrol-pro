function isWithinWindow(dateStr, windowDays) {
  if (!dateStr) return true; // невідома дата — пропускаємо
  try {
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return true;
    const cutoff = new Date();
    cutoff.setDate(cutoff.getDate() - windowDays);
    return d >= cutoff;
  } catch(e) { return true; }
}

function parseLooseDateMs(dateStr) {
  const s = String(dateStr || '').trim();
  if (!s) return 0;
  const direct = Date.parse(s);
  if (Number.isFinite(direct)) return direct;

  let m = s.match(/(20\d{2})-(\d{2})-(\d{2})/);
  if (m) return Date.parse(m[0]);

  m = s.match(/(\d{1,2})[.\/](\d{1,2})[.\/](20\d{2})/);
  if (m) return Date.parse(m[3] + '-' + m[2].padStart(2,'0') + '-' + m[1].padStart(2,'0'));

  m = s.match(/(\d{1,2})[.\/](\d{1,2})[.\/](\d{2})(?!\d)/);
  if (m) return Date.parse('20' + m[3] + '-' + m[2].padStart(2,'0') + '-' + m[1].padStart(2,'0'));

  m = s.match(new RegExp('(\\d{1,2})[\\s\\-.]+(' + ALL_MONTH_NAMES + ')[\\s\\-.,]+(20\\d{2})', 'i'));
  if (m) return Date.parse(m[3] + '-' + (MONTHS_MAP[m[2].toLowerCase()] || '01') + '-' + m[1].padStart(2,'0'));

  m = s.match(new RegExp('(' + ALL_MONTH_NAMES + ')[\\s\\-.]+?(\\d{1,2})[\\s,]+(20\\d{2})', 'i'));
  if (m) return Date.parse(m[3] + '-' + (MONTHS_MAP[m[1].toLowerCase()] || '01') + '-' + m[2].padStart(2,'0'));

  return 0;
}

function isOlderThanDays(dateStr, maxAgeDays) {
  if (!dateStr) return false;
  const ms = parseLooseDateMs(dateStr);
  if (!ms) return false;
  const cutoff = Date.now() - maxAgeDays * 24 * 3600 * 1000;
  return ms < cutoff;
}

function isLikelyUkrainianText(text) {
  const s = String(text || '').toLowerCase().replace(/https?:\/\/\S+/g, ' ').replace(/\s+/g, ' ').trim();
  if (!s) return true;

  const lat = (s.match(/[a-z]/g) || []).length;
  const cyr = (s.match(/[а-щьюяєіїґ]/g) || []).length;
  if (!lat && !cyr) return true;
  if (lat >= 14 && lat > cyr * 1.2) return false;
  if (/[ыэъё]/.test(s) && !/[іїєґ]/.test(s)) return false;

  const uaWordSignals = [
    ' та ', ' що ', ' для ', ' від ', ' про ', ' грома', ' заяв', ' грант',
    ' конкурс', ' підтрим', ' можлив', ' подати', ' кінцев', ' термін', ' ветеран', ' бізнес'
  ];
  const uaSignalCount = uaWordSignals.reduce((acc, token) => acc + (s.includes(token) ? 1 : 0), 0)
    + ((s.match(/[іїєґ]/g) || []).length > 0 ? 1 : 0);

  if (cyr >= 8 && uaSignalCount > 0) return true;
  if (cyr >= 24 && lat <= cyr * 0.35) return true;
  return false;
}

