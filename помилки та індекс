function kyivTime() {
  return new Date().toLocaleString('sv-SE', { timeZone: 'Europe/Kyiv' })
    .replace('T', ' ').slice(0, 19); // "2026-04-03 15:42:07"
}
function kyivTs() {
  return new Date().toLocaleString('sv-SE', { timeZone: 'Europe/Kyiv' })
    .slice(11, 19); // "15:42:07"
}

function getTimeZoneOffsetMs(timeZone, date) {
  const dtf = new Intl.DateTimeFormat('sv-SE', {
    timeZone,
    year: 'numeric', month: '2-digit', day: '2-digit',
    hour: '2-digit', minute: '2-digit', second: '2-digit',
    hour12: false
  });
  const parts = dtf.formatToParts(date).reduce((acc, p) => {
    if (p.type !== 'literal') acc[p.type] = p.value;
    return acc;
  }, {});
  const asUtc = Date.UTC(
    Number(parts.year), Number(parts.month) - 1, Number(parts.day),
    Number(parts.hour), Number(parts.minute), Number(parts.second)
  );
  return asUtc - date.getTime();
}

function parseStoredDateMs(value) {
  if (!value) return 0;
  if (value instanceof Date) return value.getTime();
  const s = String(value).trim();
  if (!s) return 0;
  if (/^\d{4}-\d{2}-\d{2} \d{2}:\d{2}(:\d{2})?$/.test(s)) {
    const m = s.match(/^(\d{4})-(\d{2})-(\d{2}) (\d{2}):(\d{2})(?::(\d{2}))?$/);
    if (m) {
      const y = Number(m[1]), mo = Number(m[2]), d = Number(m[3]);
      const h = Number(m[4]), mi = Number(m[5]), se = Number(m[6] || 0);
      const guessUtc = new Date(Date.UTC(y, mo - 1, d, h, mi, se));
      const offsetMs = getTimeZoneOffsetMs('Europe/Kyiv', guessUtc);
      return Date.UTC(y, mo - 1, d, h, mi, se) - offsetMs;
    }
  }
  const ms = Date.parse(s);
  return Number.isFinite(ms) ? ms : 0;
}

function toKyivDisplay(value) {
  if (!value) return '';
  const s = String(value).trim();
  if (/^\d{4}-\d{2}-\d{2} \d{2}:\d{2}(:\d{2})?$/.test(s)) return s.slice(0, 19);
  const ms = parseStoredDateMs(s);
  if (!ms) return s.slice(0, 19).replace('T', ' ');
  return new Date(ms).toLocaleString('sv-SE', { timeZone: 'Europe/Kyiv' }).replace('T', ' ').slice(0, 19);
}

