async function fetchDetailPage(url) {
  if (!url || url.length < 10) return null;
  try {
    const controller = new AbortController();
    const timer = setTimeout(() => controller.abort(), 12000);
    const resp = await fetch(url, {
      headers: {
        'User-Agent': UA,
        'Accept': 'text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8',
        'Accept-Language': 'uk,en;q=0.9'
      },
      signal: controller.signal,
      redirect: 'follow'
    });
    clearTimeout(timer);
    if (!resp.ok) return null;
    const html = await resp.text();
    const $ = cheerio.load(html);
    $('script,style,nav,header,footer,aside,.menu,.sidebar,.nav,.cookie,.popup,.social,.share,.comments').remove();

    const metaBits = [];
    ['meta[name="description"]','meta[property="og:description"]','meta[name="twitter:description"]'].forEach(sel => {
      const v = $(sel).attr('content');
      if (v) metaBits.push(v);
    });

    const selectors = [
      'article', '.entry-content', '.post-content', '.article-body',
      '.content', '.post', '.entry', 'main', '.page-content',
      '.grant-detail', '.single-post', '.field--type-text-with-summary',
      '[class*="content"]', '[class*="article"]', '[class*="post"]'
    ];
    let text = '';
    for (const sel of selectors) {
      text = $(sel).first().text().trim();
      if (text && text.length > 100) break;
    }
    if (!text || text.length < 80) {
      const ld = [];
      $('script[type="application/ld+json"]').each(function() {
        const raw = $(this).html() || '';
        if (raw) ld.push(raw.slice(0, 2000));
      });
      if (ld.length) metaBits.push(ld.join(' '));
    }
    if (!text || text.length < 50) text = $('body').text().trim();

    const merged = (metaBits.join(' ') + ' ' + text).replace(/\s+/g,' ').trim();
    return merged.slice(0, 7000);
  } catch(e) { return null; }
}

