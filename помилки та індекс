function hasGrantSignal(text) {
  const hay = String(text || '').toLowerCase();
  if (!hay) return false;
  if (GRANT_WORDS.some(w => hay.includes(w))) return true;
  const pairSets = [
    ['подати', 'заяв'], ['кінцев', 'термін'], ['deadline', 'apply'],
    ['funding', 'application'], ['open', 'call'], ['call', 'proposal'],
    ['receive', 'funding'], ['eligible', 'applic'], ['grant', 'support'],
    ['громад', 'проєкт'], ['організац', 'підтримк']
  ];
  return pairSets.some(pair => pair.every(token => hay.includes(token)));
}

function passesFilter(title, desc, src, relaxed) {
  const safeTitle = String(title || '').trim();
  const safeDesc  = String(desc  || '').trim();
  const currentUrl = String((src && src._current_url) || '').toLowerCase();
  if (!safeTitle && !safeDesc) return false;
  if (safeTitle && BAD_TITLE.some(re => re.test(safeTitle))) return false;

  const hay = (safeTitle + ' ' + safeDesc).toLowerCase().replace(/\s+/g, ' ').trim();
  const hayWithUrl = (hay + ' ' + currentUrl).trim();
  if (SPAM.some(w => hayWithUrl.includes(w))) return false;

  const excKw = (src && src.link_exclude)
    ? src.link_exclude.toLowerCase().split(',').map(s => s.trim()).filter(Boolean)
    : [];
  if (excKw.length > 0 && excKw.some(w => hayWithUrl.includes(w))) return false;

  const kw = (src && src.source_keywords)
    ? src.source_keywords.toLowerCase().split(',').map(s => s.trim()).filter(Boolean)
    : [];
  if (kw.length > 0 && kw.some(w => hayWithUrl.includes(w))) return true;

  const incKw = (src && src.link_include)
    ? src.link_include.toLowerCase().split(',').map(s => s.trim()).filter(Boolean)
    : [];
  if (incKw.length > 0 && incKw.some(w => hayWithUrl.includes(w))) return true;

  if (relaxed) return safeTitle.length >= 6 || safeDesc.length >= 40;

  if (safeTitle.length < 5 && safeDesc.length < 20 && !currentUrl) return false;
  if (hasGrantSignal(hayWithUrl)) return true;
  if (safeTitle.length < 30 && currentUrl && hasGrantSignal(currentUrl)) return true;
  if (safeDesc.length >= 60 && hasGrantSignal(safeDesc)) return true;

  return false;
}

